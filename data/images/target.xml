<mujoco model="mug_rack">
    <visual>
        <headlight ambient="0.3 0.3 0.3" diffuse="0.3 0.3 0.3" specular="0.1 0.1 0.1"/>
    </visual>

    <asset>
        <texture name="tex_wood" type="2d" builtin="flat" rgb1="0.4 0.25 0.15" rgb2="0.45 0.3 0.2" width="512" height="512"/>
        <material name="mat_wood" texture="tex_wood" specular="0.1" shininess="0.1"/>

        <texture name="tex_sky" type="skybox" builtin="gradient" rgb1="0.4 0.6 0.85" rgb2="1.0 1.0 1.0" width="256" height="256"/>

        <texture name="tex_floor" type="2d" builtin="checker" rgb1="0.75 0.75 0.78" rgb2="0.88 0.88 0.9" width="512" height="512"/>
        <material name="mat_floor" texture="tex_floor" texrepeat="4 4" specular="0.1" shininess="0.1"/>
    </asset>

    <worldbody>
        <geom name="floor" type="plane" size="3 3 0.1" material="mat_floor"/>

        <light name="light_key"  directional="true" castshadow="true"  pos="1.5 -1.5 3" dir="-0.4 0.4 -1" diffuse="0.7 0.7 0.65" specular="0.3 0.3 0.3"/>
        <light name="light_fill" directional="true" castshadow="false" pos="-1.5 1.5 2" dir="0.4 -0.4 -1" diffuse="0.25 0.25 0.3"/>
        <body name="camera_center" pos="0 0 0 "/>
        <body name="mug_rack" pos="0.0 0.2 0.0" euler="0 0 -180">
            <geom name="base" type="cylinder" size="0.11 0.014" pos="0 0 0.014" material="mat_wood"/>

            <geom name="pole" type="cylinder" size="0.02 0.20" pos="0 0 0.216" material="mat_wood"/>

            <geom name="branch_top_1" type="capsule" size="0.008 0.072" pos="0.045 0 0.338" euler="0 50 0" material="mat_wood"/>
            <geom name="branch_top_2" type="capsule" size="0.008 0.072" pos="-0.045 0 0.338" euler="0 -50 0" material="mat_wood"/>

            <geom name="branch_mid_1" type="capsule" size="0.016 0.072" pos="0 0.0474 0.2099" euler="-50 0 0" material="mat_wood"/>
            <geom name="branch_mid_1_tip" type="capsule" size="0.016 0.036" pos="0 0.10 0.2990" euler="0 0 0" material="mat_wood"/>
            <geom name="branch_mid_1_tip2" type="capsule" size="0.016 0.036" pos="0 0.1276 0.3581" euler="-50 0 0" material="mat_wood"/>
            <geom name="branch_mid_2" type="capsule" size="0.008 0.072" pos="0 -0.045 0.203" euler="50 0 0" material="mat_wood"/>
        </body>

        <camera name="cam1" pos="0.7 0.1 0.75" mode="targetbody" target="camera_center"/>
        <camera name="cam2" pos="-0.5 0.5 0.75" mode="targetbody" target="camera_center"/>
        <camera name="cam3" pos="-0.5 -0.5 0.75" mode="targetbody" target="camera_center"/>
    </worldbody>
</mujoco>